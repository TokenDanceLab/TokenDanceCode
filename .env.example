# TokenDanceCode local provider env example
#
# TokenDanceCode does not load the repository root .env by default.
# Use these values in a controlled shell, in SDK env injection, or in a
# user-global ~/.tokendance/.env file. Do not commit real keys.

# OpenAI Responses API
OPENAI_API_KEY=<openai-api-key>

# Anthropic-compatible Messages API
ANTHROPIC_API_KEY=<anthropic-api-key>

# TokenDance Gateway through the OpenAI-compatible Chat Completions adapter
TOKENDANCE_PROVIDER=openai-chat-completions
TOKENDANCE_GATEWAY_API_KEY=<tokendance-gateway-api-key>
TOKENDANCE_GATEWAY_BASE_URL=https://api.example.com/v1
TOKENDANCE_MODEL=<model-name>

# Generic model hint used by the CLI config loader when provider can be inferred
MODEL_ID=<model-name>
