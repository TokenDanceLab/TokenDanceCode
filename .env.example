# Anthropic API Key（必填）
# 获取地址：https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# 模型 ID（必填）
# 可选：claude-sonnet-4-6, claude-opus-4-8, deepseek-v4-pro 等
MODEL_ID=claude-sonnet-4-6

# 自定义 Base URL（可选，用于 Anthropic 兼容的第三方供应商）
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# =============================================================================
#  Anthropic 兼容供应商参考
#
#  供应商      MODEL_ID              Base URL
#  ──────────  ────────────────────  ──────────────────────────────────
#  Anthropic   claude-sonnet-4-6     （留空使用默认）
#  DeepSeek    deepseek-chat         https://api.deepseek.com/anthropic
#  MiniMax     MiniMax-M2.5          https://api.minimax.io/anthropic
#  GLM (Zhipu) glm-5                 https://api.z.ai/api/anthropic
#  Kimi        kimi-k2.5             https://api.moonshot.ai/anthropic
# =============================================================================
